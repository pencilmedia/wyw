<script type="text/javascript">
// Check if content overflows and add class for footer shadow
function checkContentOverflow() {
	const body = document.body;
	const cardboardTop = document.getElementById('cardboard_top');
	
	if (cardboardTop) {
		// Check if content actually overflows the container
		// Use clientHeight (visible height) vs scrollHeight (total content height)
		const hasVerticalScrollbar = cardboardTop.scrollHeight > cardboardTop.clientHeight;
		
		if (hasVerticalScrollbar) {
			body.classList.add('content-overflow');
			cardboardTop.classList.add('needs-scroll');
		} else {
			body.classList.remove('content-overflow');
			cardboardTop.classList.remove('needs-scroll');
		}
	}
}

// Check on load, DOMContentLoaded, and resize
document.addEventListener('DOMContentLoaded', function() {
	setTimeout(checkContentOverflow, 100);
});
window.addEventListener('load', function() {
	setTimeout(checkContentOverflow, 100);
});
window.addEventListener('resize', function() {
	setTimeout(checkContentOverflow, 100);
});
</script>

